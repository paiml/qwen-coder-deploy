[Unit]
Description=Qwen Coder 1.5B - llama.cpp Inference Server
After=network.target

[Service]
Type=simple
User=noah
ExecStart=/home/noah/.cargo/bin/llama-server \
    --model /home/noah/models/qwen-coder-1.5b/qwen-coder-1.5b-q4_k_m.gguf \
    --host 0.0.0.0 \
    --port 8083 \
    --threads 4 \
    --ctx-size 4096
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
